# ============================================================
# PLANCLUB — .gitignore
# ============================================================

# ============================================================
# 1. VARIABLES DE ENTORNO
# ============================================================
.env
.env.*
!.env.example
*.secret
secrets.json

# ============================================================
# 2. BASES DE DATOS
# ============================================================
*.db
*.sqlite
*.sqlite3
instance/
backend/instance/

# ============================================================
# 3. PYTHON
# ============================================================
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python

# ============================================================
# 4. ENTORNOS VIRTUALES
# ============================================================
venv/
env/
ENV/
.venv/

# ============================================================
# 5. VS CODE
# ============================================================
.vscode/settings.json
.vscode/launch.json

# (Compartir si quieren)
# .vscode/extensions.json

# ============================================================
# 6. LOGS
# ============================================================
*.log
*.tmp
*.temp

# ============================================================
# 7. CACHE
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.pyre/

# ============================================================
# 8. COVERAGE
# ============================================================
.coverage
.coverage.*
htmlcov/

# ============================================================
# 9. BUILD
# ============================================================
dist/
build/
*.egg-info/
*.egg
MANIFEST
pip-wheel-metadata/

# ============================================================
# 10. FLASK
# ============================================================
flask_session/
instance/*.db

# ============================================================
# 11. JUPYTER (por si algún día usan notebooks)
# ============================================================
.ipynb_checkpoints/

# ============================================================
# 12. WINDOWS
# ============================================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# 13. MAC
# ============================================================
.DS_Store
.AppleDouble
.LSOverride

# ============================================================
# 14. BACKUPS
# ============================================================
*.bak
*.old
*.orig