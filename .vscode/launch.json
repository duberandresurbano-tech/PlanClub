    "version": "0.2.0",
    "configurations": [
        {
            "type": "firefox",
            "request": "launch",
            "name": "Iniciar Firefox para PlanClub",
            "url": "http://127.0.0.1:5050",
            "webRoot": "${workspaceFolder}",
            "reAttach": true,
            "pathMappings": [
                {
                    "url": "http://127.0.0.1:5050",
                    "path": "${workspaceFolder}"
                }
            ]
        }
    ]
}