{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Run PlanClub",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "FLASK_ENV": "development"
            }
        },
        {
            "type": "firefox",
            "request": "launch",
            "name": "Abrir Firefox",
            "url": "http://127.0.0.1:5050",
            "webRoot": "${workspaceFolder}",
            "reAttach": true,
            "preLaunchTask": "wait-for-flask"
        }
    ],
    "compounds": [
        {
            "name": "PlanClub (Flask + Firefox)",
            "configurations": ["Python: Run PlanClub", "Abrir Firefox"],
            "stopAll": true
        }
    ]
}